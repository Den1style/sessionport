{
  "manifest_version": 3,
  "name": "SessionPort",
  "version": "1.0.3",
  "description": "Transfer LLM context between Claude, ChatGPT, Grok, Gemini, Mistral, Deepseek and Perplexity without copy-paste. Saves snapshots, tracks history, attaches files.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs",
    "alarms",
    "identity"
  ],
  "oauth2": {
    "client_id": "747235685517-65bdjpj98b5bi339ulisb82gffg0bmt9.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://grok.com/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://chat.mistral.ai/*",
        "https://chat.deepseek.com/*"
      ],
      "js": [
        "content-bundle.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://chat.mistral.ai/*"
      ],
      "js": [
        "main-world-inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "shared-utils.js",
        "dashboard.html",
        "map-renderer.js"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://grok.com/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://chat.mistral.ai/*",
        "https://chat.deepseek.com/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://grok.com/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://chat.mistral.ai/*",
    "https://chat.deepseek.com/*",
    "https://www.googleapis.com/",
    "https://oauth2.googleapis.com/"
  ]
}